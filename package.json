{
  "name": "plone-mcp",
  "version": "1.0.0",
  "description": "Model Context Protocol server for Plone CMS REST API integration",
  "keywords": [
    "mcp",
    "plone",
    "cms",
    "rest-api"
  ],
  "type": "module",
  "scripts": {
    "prepare": "npm run build",
    "build": "tsc --project tsconfig.build.json && copyfiles -u 1 src/blocks.json dist/ && chmod 755 dist/stdio-server.js",
    "clean": "node -e \"fs.rmSync('dist', { recursive: true, force: true })\"",
    "build:clean": "pnpm run clean && pnpm run build",
    "start": "node dist/http-server.js",
    "stdio": "node dist/stdio-server.js",
    "lint": "eslint src __tests__",
    "lint:fix": "eslint src __tests__ --fix",
    "type-check:src": "tsc --project tsconfig.build.json --noEmit",
    "type-check:tests": "tsc --project tsconfig.json --noEmit",
    "type-check": "pnpm run type-check:src && pnpm run type-check:tests",
    "test": "vitest run",
    "test:unit": "vitest run __tests__/unit",
    "test:integration": "vitest run __tests__/integration",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "main": "dist/http-server.js",
  "bin": {
    "plone-mcp": "dist/stdio-server.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "axios": "^1.6.0",
    "express": "^5.2.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-supersub": "^1.0.0",
    "unified": "^11.0.5",
    "uuid": "^11.1.0",
    "zod": "^4.0.10"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.39.1",
    "@modelcontextprotocol/inspector": "^0.17.2",
    "@types/express": "^5.0.0",
    "@types/mdast": "^4.0.4",
    "@types/node": "^22.12.0",
    "@typescript-eslint/eslint-plugin": "^8.46.4",
    "@typescript-eslint/parser": "^8.46.4",
    "@vitest/coverage-v8": "^4.0.8",
    "copyfiles": "^2.4.1",
    "eslint": "^9.39.1",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^16.5.0",
    "nock": "^13.5.0",
    "prettier": "^3.6.2",
    "tsx": "^4.0.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.47.0",
    "vitest": "^4.0.8"
  },
  "packageManager": "pnpm@10.32.1"
}
