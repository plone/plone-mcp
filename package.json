{
  "name": "plone-mcp-server",
  "version": "1.0.0",
  "description": "Model Context Protocol server for Plone CMS REST API integration",
  "keywords": [
    "mcp",
    "plone",
    "cms",
    "rest-api"
  ],
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/http-server.js",
    "stdio": "node dist/stdio-server.js",
    "type-check:src": "tsc --project tsconfig.json --noEmit",
    "type-check:tests": "tsc --project tsconfig.test.json --noEmit",
    "type-check": "pnpm run type-check:src && pnpm run type-check:tests",
    "test": "vitest run",
    "test:unit": "vitest run __tests__/unit",
    "test:integration": "vitest run __tests__/integration",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "main": "dist/http-server.js",
  "bin": {
    "plone-mcp-server": "dist/stdio-server.js"
  },
  "files": [
    "dist"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/inspector": "^0.17.2",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@hono/node-server": "^1.19.9",
    "axios": "^1.6.0",
    "express": "^4.19.2",
    "hono": "^4.11.4",
    "isomorphic-fetch": "^3.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-supersub": "^1.0.0",
    "unified": "^11.0.5",
    "uuid": "^11.1.0",
    "zod": "^4.0.10"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.39.1",
    "@types/express": "^4.17.21",
    "@types/mdast": "^4.0.4",
    "@types/node": "^22.12.0",
    "@typescript-eslint/eslint-plugin": "^8.46.4",
    "@typescript-eslint/parser": "^8.46.4",
    "@vitest/coverage-v8": "^4.0.8",
    "copyfiles": "^2.4.1",
    "eslint": "^9.39.1",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^16.5.0",
    "jsdom": "^27.2.0",
    "nock": "^13.5.0",
    "path": "^0.12.7",
    "prettier": "^3.6.2",
    "supertest": "^6.3.0",
    "ts-morph": "^27.0.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.0.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.47.0",
    "vitest": "^4.0.8"
  },
  "packageManager": "pnpm@10.32.1"
}
