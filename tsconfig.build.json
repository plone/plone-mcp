{
  // Build config: strict NodeNext resolution (enforces explicit .js
  // extensions in src imports) and the only config that emits to dist/.
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": false,
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "types": ["node"],
    "paths": {}
  },
  "include": ["src/**/*.ts"]
}
